# tokensleft reads manual keys from ~/.tokensleft/.env (any directory, e.g.
# `npx tokensleft`) and ./.env (current directory, wins on conflicts).
# Everything here is optional — logged-in CLIs are auto-detected.

# ============================== z.ai ==============================
# Keys are ALSO auto-discovered from Claude Code profiles
# (~/.claude/settings*.json with ANTHROPIC_BASE_URL pointing at api.z.ai).
# Disable with: ZAI_AUTO_DISCOVER=0
# Numbered accounts. Each key can use a different proxy.
ZAI_API_KEY_1=your_zai_api_key_1
ZAI_PROXY_1=http://127.0.0.1:7890
ZAI_NAME_1=main

ZAI_API_KEY_2=your_zai_api_key_2
ZAI_PROXY_2=

# These aliases are also supported:
# ZAI_KEY_1=your_zai_api_key_1
# GLM_API_KEY_1=your_zai_api_key_1

# Single account fallback:
# ZAI_API_KEY=your_zai_api_key
# ZAI_PROXY=http://127.0.0.1:7890

# Comma-separated fallback:
# ZAI_API_KEYS=key_a,key_b,key_c
# ZAI_PROXIES=http://127.0.0.1:7890,,http://127.0.0.1:7891

# Refresh interval in seconds (default 60):
# ZAI_REFRESH_SECONDS=60

# =========================== Claude Code ===========================
# The system key is read automatically from ~/.claude/.credentials.json
# (Claude Code keeps it fresh; the dashboard re-reads it every refresh).
# Nothing is required here unless you want extras:

# Use a different Claude config directory:
# CLAUDE_CONFIG_DIR=C:\Users\me\.claude

# Skip the auto-detected system key:
# CLAUDE_DISABLE_SYSTEM_KEY=1

# Manual OAuth tokens (from `claude setup-token`, or another machine's
# .credentials.json). Numbered accounts with optional names:
# CLAUDE_TOKEN_1=sk-ant-oat01-...
# CLAUDE_NAME_1=work
# CLAUDE_TOKEN_2=sk-ant-oat01-...
# CLAUDE_NAME_2=personal

# Single manual token (same variable Claude Code itself understands):
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...
# CLAUDE_NAME=manual

# Refresh interval in seconds (default 300):
# CLAUDE_REFRESH_SECONDS=300

# ============================= Codex ==============================
# Auto-detected from ~/.codex/auth.json (or CODEX_HOME/auth.json).
# Tokens are refreshed automatically via OpenAI's OAuth endpoint.
# CODEX_HOME=C:\Users\me\.codex
# CODEX_REFRESH_SECONDS=300

# ============================= Gemini =============================
# Auto-detected from ~/.gemini/oauth_creds.json (gemini CLI login).
# Tokens are refreshed automatically via Google's OAuth endpoint.
# GEMINI_CLI_HOME=C:\Users\me\.gemini
# GEMINI_REFRESH_SECONDS=300

# ============================= Copilot ============================
# Auto-detected from Copilot's apps.json/hosts.json or gh CLI hosts.yml.
# Manual token (a GitHub OAuth token with Copilot access):
# COPILOT_TOKEN=gho_...
# COPILOT_REFRESH_SECONDS=300

# ============================== Grok ==============================
# Auto-detected from ~/.grok/auth.json (grok login).
# GROK_TOKEN=...
# GROK_AUTH_PATH=C:\Users\me\.grok\auth.json
# GROK_REFRESH_SECONDS=300

# =========================== Antigravity ==========================
# Auto-detected from Antigravity's state.vscdb; refreshed tokens are
# cached in ~/.tokensleft/antigravity-auth.json.
# ANTIGRAVITY_STATE_DB=C:\Users\me\AppData\Roaming\Antigravity\User\globalStorage\state.vscdb
# ANTIGRAVITY_REFRESH_SECONDS=300

# ============================ OpenCode ============================
# Auto-detected from ~/.local/share/opencode (auth.json + opencode.db).
# OPENCODE_DATA_DIR=C:\Users\me\.local\share\opencode
# OPENCODE_REFRESH_SECONDS=300
